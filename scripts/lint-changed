#!/usr/bin/env python3
"""PostToolUse edit-time lint hook (photo_ops-8d5). Contract:
docs/superpowers/specs/2026-07-02-lint-hook-design.md

Reads the hook JSON from stdin, runs the fast per-file linter for the edited
file, and exits 2 (feeding the linter output back to the agent) when it finds
issues. Clean / skip / LINT_HOOK=0 / bad-stdin / no file_path / absent tool -> 0.
"""
from __future__ import annotations

import json
import os
import subprocess
import sys

# Resolve `from scripts.linthook...` regardless of the caller's CWD.
_REPO_ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
if _REPO_ROOT not in sys.path:
    sys.path.insert(0, _REPO_ROOT)

from scripts.linthook.dispatch import linter_for  # noqa: E402


def main() -> int:
    if os.environ.get("LINT_HOOK") == "0":
        return 0
    try:
        payload = json.load(sys.stdin)
    except (json.JSONDecodeError, ValueError):
        return 0
    file_path = (payload.get("tool_input") or {}).get("file_path")
    if not file_path:
        return 0
    linter = linter_for(file_path)
    if linter is None:
        return 0
    try:
        result = subprocess.run(linter.cmd, capture_output=True, text=True)
    except FileNotFoundError:
        # Linter tool not installed — don't punish the edit for a missing dev tool.
        return 0
    if linter.issue_on == "exit":
        issue = result.returncode != 0
    else:  # "output": non-empty stdout means an issue (e.g. gofmt -l)
        issue = bool(result.stdout.strip())
    if issue:
        sys.stderr.write((result.stdout or "") + (result.stderr or ""))
        return 2
    return 0


if __name__ == "__main__":
    sys.exit(main())
