{
  "permissions": {
    "allow": [
      "Bash(bd:*)",

      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git rev-parse:*)",
      "Bash(git branch:*)",
      "Bash(git switch:*)",
      "Bash(git checkout:*)",
      "Bash(git restore:*)",
      "Bash(git add:*)",
      "Bash(git mv:*)",
      "Bash(git commit:*)",
      "Bash(git merge:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git remote:*)",
      "Bash(git check-ignore:*)",
      "Bash(git ls-files:*)",

      "Bash(gh run:*)",
      "Bash(gh auth:*)",

      "Bash(make gate:*)",
      "Bash(make proto:*)",
      "Bash(make proto-check:*)",
      "Bash(make typecheck:*)",
      "Bash(make lint:*)",
      "Bash(make build:*)",
      "Bash(make test:*)",
      "Bash(make smoke:*)",
      "Bash(make migrate:*)",
      "Bash(make status:*)",
      "Bash(make logs:*)",

      "Bash(scripts/sdd:*)",
      "Bash(./scripts/sdd:*)",
      "Bash(sh scripts/test-smoke-upload-contract.sh)",
      "Bash(scripts/smoke-upload.sh)",
      "Bash(scripts/smoke-auth-upload-ownership.sh)"
    ]
  },
  "hooks": {
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bd prime"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "scripts/lint-changed"
          }
        ]
      }
    ]
  }
}
